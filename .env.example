# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=brewcrm

# Redis (Upstash — get URL from https://console.upstash.com)
UPSTASH_REDIS_URL=rediss://default:YOUR_TOKEN@YOUR_HOST.upstash.io:6379

# LLM
LLM_PROVIDER=gemini
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Services
CRM_API_URL=http://localhost:3000
CHANNEL_STUB_URL=http://localhost:3001

# CORS
FRONTEND_URL=http://localhost:3002
